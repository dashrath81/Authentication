generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  EMPLOYEE
  MANAGER
}

enum Status {
  ASSIGNED
  PEDING
  IN_PROGRESS
  COMPLETED
}

model Employee {
  id       Int    @id @default(autoincrement())
  name     String
  email    String @unique
  password String
  role     Role   @default(EMPLOYEE)

  profile         Profile?
  tasks           Tasks[]
  projects        ProjectMember[]
  createdProjects Project[]       @relation("ProjectCreator")

  departmentId Int?
  Department   Department? @relation(fields: [departmentId], references: [id])

  leavesRequested Leave[] @relation("EmployeeLeaves")
  leavesApproved  Leave[] @relation("LeaveApprover")
}

model Profile {
  id          Int       @id @default(autoincrement())
  dateOfBirth DateTime?
  phone       String?
  address     String?
  city        String?
  skills      String?

  image String?

  employeeId Int      @unique
  employee   Employee @relation(fields: [employeeId], references: [id])
}

model Department {
  id          Int     @id @default(autoincrement())
  name        String
  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employee Employee[]
}

model Tasks {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  dueDate     DateTime
  status      Status

  createdAt DateTime @default(now())

  employeeId Int
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

model Project {
  id          Int             @id @default(autoincrement())
  name        String
  description String
  createdAt   DateTime        @default(now())
  createdBy   Int
  deadline    DateTime
  creator     Employee        @relation("ProjectCreator", fields: [createdBy], references: [id])
  members     ProjectMember[]
}

model ProjectMember {
  id         Int      @id @default(autoincrement())
  employeeId Int
  projectID  Int
  assignedAt DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  project  Project  @relation(fields: [projectID], references: [id], onDelete: Cascade)

  @@unique([employeeId, projectID])
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

enum LeaveType {
  CASUAL
  SICK
  ANNUAL
  UNPAID
  MATERNITY
  PATERNITY
}

model Leave {
  id         Int         @id @default(autoincrement())
  employeeId Int
  approvedBy Int?
  leaveType  LeaveType
  startDate  DateTime
  endDate    DateTime
  reason     String
  status     LeaveStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt  DateTime @updatedAt
  approvedAt DateTime?

  employee Employee  @relation("EmployeeLeaves", fields: [employeeId], references: [id])
  approver Employee? @relation("LeaveApprover", fields: [approvedBy], references: [id])

  @@index([employeeId])
  @@index([approvedBy])
  @@index([status])
}
