generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  EMPLOYEE
}

enum Status {
  ASSIGNED
  PEDING
  IN_PROGRESS
  COMPLETED
}

model Employee {
  id       Int      @id @default(autoincrement())
  name     String
  email    String   @unique
  password String
  role     Role     @default(EMPLOYEE)
  profile  Profile?
  tasks    Tasks[]
}

model Profile {
  id          Int       @id @default(autoincrement())
  dateOfBirth DateTime?
  phone       String?
  address     String?
  city        String?
  skills      String?

  employeeId Int      @unique
  employee   Employee @relation(fields: [employeeId], references: [id])
}

model Tasks {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  dueDate     DateTime
  status      Status

  createdAt DateTime @default(now())

  employeeId Int
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}
